# Frontend Environment Template (Vite)
#
# Purpose:
# - Centralize frontend runtime configuration.
# - Prevent hardcoded chain IDs, addresses, and RPC URLs in source files.
#
# Usage:
# 1) Copy this file to frontend/.env
# 2) Fill values for your active network (for example Sepolia)
# 3) Restart the Vite dev server after changes

# Chain ID used for wallet/network checks (11155111 = Sepolia)
VITE_CHAIN_ID=11155111

# Read-only RPC endpoint used by the frontend
VITE_RPC_URL=

# Deployed StreamFactory address used by the app
VITE_FACTORY_ADDRESS=

# Optional explorer URL for tx links and contract links in UI
VITE_BLOCK_EXPLORER_BASE_URL=https://sepolia.etherscan.io
