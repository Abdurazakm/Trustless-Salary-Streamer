# Trustless Salary Streamer - Environment Template
#
# Purpose:
# - Keep sensitive values out of source control.
# - Standardize local, testnet, and production configuration.
#
# How to apply:
# 1) Copy this file to contracts/.env for Foundry scripts/tests.
# 2) Copy relevant VITE_* variables to frontend/.env for the web app.
# 3) Never commit real private keys or secrets.

# -----------------------------------------------------------------------------
# Blockchain / Deployment (Foundry)
# -----------------------------------------------------------------------------

# RPC endpoint used by Foundry for deployments, scripts, and fork tests.
SEPOLIA_RPC_URL=

# Deployer wallet private key (without 0x prefix).
# Use a dedicated funded test wallet only.
DEPLOYER_PRIVATE_KEY=

# Optional: Etherscan API key for source verification.
ETHERSCAN_API_KEY=

# Optional: Gas reporting / monitoring integrations.
COINMARKETCAP_API_KEY=


# -----------------------------------------------------------------------------
# Deployed Contract Addresses
# -----------------------------------------------------------------------------

# StreamFactory deployed address.
STREAM_FACTORY_ADDRESS=

# Optional: if deployment architecture uses a separate implementation contract.
TRUSTLESS_SALARY_STREAMER_IMPLEMENTATION_ADDRESS=


# -----------------------------------------------------------------------------
# Frontend (Vite)
# Note: Vite only exposes variables prefixed with VITE_.
# -----------------------------------------------------------------------------

# Chain ID used by the frontend (11155111 = Sepolia).
VITE_CHAIN_ID=11155111

# Read RPC URL for frontend reads/fallback provider.
VITE_RPC_URL=

# Address the UI uses for creating/fetching streams.
VITE_STREAM_FACTORY_ADDRESS=

# Optional explorer URL used for transaction links.
VITE_BLOCK_EXPLORER_BASE_URL=https://sepolia.etherscan.io
